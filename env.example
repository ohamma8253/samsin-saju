# Samsin Saju — Environment Variables Template
# Copy this file: cp env.example .env.local  then fill in your keys

# ─── Required ──────────────────────────────────────────────────────────
# OpenRouter API key — get one free at https://openrouter.ai
# Supports 100+ models including Claude, GPT-5, Gemini, and more.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ─── Optional: Override LLM routing per role ───────────────────────────
# Default models are configured in lib/llm/samsin-model-router.ts
# All model IDs follow OpenRouter format (provider/model-name)

# Three-tradition native analysis (사주팔자 / 자미두수 / 서양점성)
# SAMSIN_LLM_SAJU_PRIMARY=anthropic/claude-sonnet-4.5
# SAMSIN_LLM_SAJU_FALLBACKS=anthropic/claude-haiku-4.5

# SAMSIN_LLM_ZIWEI_PRIMARY=anthropic/claude-sonnet-4.5
# SAMSIN_LLM_ZIWEI_FALLBACKS=anthropic/claude-haiku-4.5

# SAMSIN_LLM_NATAL_PRIMARY=anthropic/claude-sonnet-4.5
# SAMSIN_LLM_NATAL_FALLBACKS=anthropic/claude-haiku-4.5

# Cross-tradition boundary audit
# SAMSIN_LLM_NATIVE_AUDIT_PRIMARY=openai/gpt-5-mini
# SAMSIN_LLM_NATIVE_AUDIT_FALLBACKS=openai/gpt-4o-mini

# Trinity consensus — Claude vs OpenAI cross-validation
# SAMSIN_LLM_COMPARE_PRIMARY=openai/gpt-5
# SAMSIN_LLM_COMPARE_FALLBACKS=openai/gpt-4o

# Decision synthesis
# SAMSIN_LLM_DECISION_PRIMARY=openai/gpt-5
# SAMSIN_LLM_DECISION_FALLBACKS=openai/gpt-4o

# Korean narrative rendering
# SAMSIN_LLM_RENDER_PRIMARY=anthropic/claude-sonnet-4.5
# SAMSIN_LLM_RENDER_FALLBACKS=anthropic/claude-haiku-4.5

# Final safety audit
# SAMSIN_LLM_SAFETY_PRIMARY=openai/gpt-5-mini
# SAMSIN_LLM_SAFETY_FALLBACKS=openai/gpt-4o-mini
